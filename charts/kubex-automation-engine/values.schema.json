{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "podSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    },
    "resources": {
      "$ref": "#/definitions/resources"
    },
    "gateway": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object"
        },
        "configSecretName": {
          "type": "string"
        },
        "securityContext": {
          "type": "object"
        },
        "resources": {
          "$ref": "#/definitions/resources"
        }
      }
    },
    "cleanup": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object"
        },
        "podSecurityContext": {
          "type": "object"
        },
        "securityContext": {
          "type": "object"
        }
      }
    },
    "openshift": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "fsGroup": {
          "type": [
            "integer",
            "null"
          ]
        },
        "fsGroupChangePolicy": {
          "type": "string"
        },
        "supplementalGroups": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "controllerManager": {
      "type": "object",
      "properties": {
        "leaderElection": {
          "type": "object"
        },
        "healthProbeBindAddress": {
          "type": "string"
        },
        "metricsBindAddress": {
          "type": "string"
        },
        "extraArgs": {
          "type": "array"
        },
        "globalConfigReconcileInterval": {
          "type": "string"
        },
        "extraEnv": {
          "type": "array"
        }
      }
    }
  },
  "definitions": {
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "$ref": "#/definitions/resourceList"
        },
        "requests": {
          "$ref": "#/definitions/resourceList"
        }
      }
    },
    "resourceList": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    }
  }
}
