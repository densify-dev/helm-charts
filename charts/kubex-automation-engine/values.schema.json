{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "createSecrets": {
      "type": "boolean"
    },
    "kubex": {
      "type": "object",
      "properties": {
        "url": {
          "type": "object",
          "properties": {
            "host": {
              "type": "string"
            },
            "scheme": {
              "type": "string",
              "enum": ["http", "https"]
            }
          }
        },
        "clusterName": {
          "type": "string",
          "minLength": 1
        },
        "recommendationsPath": {
          "type": "string"
        },
        "requestTimeout": {
          "type": "string"
        }
      }
    },
    "kubexCredentials": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string"
        },
        "epassword": {
          "type": "string"
        },
        "userSecretName": {
          "type": "string"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "fsGroup": {
          "type": "integer"
        },
        "runAsGroup": {
          "type": "integer"
        },
        "runAsUser": {
          "type": "integer"
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "seccompProfile": {
          "type": "object"
        }
      }
    },
    "securityContext": {
      "type": "object"
    },
    "resources": {
      "$ref": "#/definitions/resources"
    },
    "gateway": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object"
        },
        "configSecretName": {
          "type": "string"
        },
        "securityContext": {
          "type": "object"
        },
        "resources": {
          "$ref": "#/definitions/resources"
        }
      }
    },
    "cleanup": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object"
        },
        "podSecurityContext": {
          "type": "object"
        },
        "securityContext": {
          "type": "object"
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "annotations": {
          "type": "object"
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "additionalLabels": {
              "type": "object"
            },
            "namespaceSelector": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "scheme": {
              "type": "string",
              "enum": ["http", "https"]
            },
            "path": {
              "type": "string"
            },
            "interval": {
              "type": "string"
            },
            "scrapeTimeout": {
              "type": "string"
            }
          }
        }
      }
    },
    "openshift": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "fsGroup": {
          "type": ["integer", "null"]
        },
        "fsGroupChangePolicy": {
          "type": "string"
        },
        "supplementalGroups": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "controllerManager": {
      "type": "object",
      "properties": {
        "leaderElection": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "leaseDuration": {
              "type": "string"
            },
            "renewDeadline": {
              "type": "string"
            },
            "retryPeriod": {
              "type": "string"
            }
          }
        },
        "healthProbeBindAddress": {
          "type": "string"
        },
        "metricsBindAddress": {
          "type": "string"
        },
        "podAdmissionWebhookKubeAPIQPS": {
          "type": "number"
        },
        "podAdmissionWebhookKubeAPIBurst": {
          "type": "integer"
        },
        "extraArgs": {
          "type": "array"
        },
        "globalConfigReconcileInterval": {
          "type": "string"
        },
        "extraEnv": {
          "type": "array"
        }
      }
    },
    "localProposals": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "configMapName": {
          "type": "string"
        },
        "mountPath": {
          "type": "string"
        },
        "fileName": {
          "type": "string"
        }
      }
    },
    "webhook": {
      "type": "object",
      "properties": {
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        },
        "podMutation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "namePrefix": {
              "type": "string",
              "maxLength": 31,
              "pattern": "^$|^[a-z0-9](?:[-a-z0-9]{0,30})?$"
            },
            "additionalWebhook": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "namePrefix": {
                  "type": "string",
                  "maxLength": 31,
                  "pattern": "^$|^[a-z0-9](?:[-a-z0-9]{0,30})?$"
                }
              }
            }
          }
        }
      }
    },
    "globalConfiguration": {
      "type": "object",
      "properties": {
        "webhookHealth": {
          "type": "object",
          "properties": {
            "failureThreshold": {
              "type": "integer"
            },
            "successThreshold": {
              "type": "integer"
            },
            "transitionCheckInterval": {
              "type": "string"
            }
          }
        },
        "heartbeatInterval": {
          "type": "string"
        },
        "webhookOwnerResolutionRetryTimeout": {
          "type": "string"
        },
        "webhookProbe": {
          "type": "object",
          "properties": {
            "image": {
              "type": ["string", "null"]
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "resources": {
              "$ref": "#/definitions/resources"
            },
            "podSecurityContext": {
              "type": "object"
            },
            "securityContext": {
              "type": "object"
            }
          }
        }
      }
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "policy": {
            "type": "string"
          },
          "weight": {
            "type": "integer"
          },
          "namespaces": {
            "type": "object",
            "properties": {
              "operator": {
                "type": "string"
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "podLabels": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "$ref": "#/definitions/resourceList"
        },
        "requests": {
          "$ref": "#/definitions/resourceList"
        }
      }
    },
    "resourceList": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "createSecrets": {
            "const": true
          }
        }
      },
      "then": {
        "required": ["kubex", "kubexCredentials"],
        "properties": {
          "kubex": {
            "required": ["url"],
            "properties": {
              "url": {
                "required": ["host"],
                "properties": {
                  "host": {
                    "minLength": 1
                  }
                }
              }
            }
          },
          "kubexCredentials": {
            "required": [
              "username",
              "epassword"
            ],
            "properties": {
              "username": {
                "minLength": 1
              },
              "epassword": {
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
