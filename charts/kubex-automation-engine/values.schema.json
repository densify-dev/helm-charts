{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "createSecrets": {
      "type": "boolean"
    },
    "kubex": {
      "type": "object",
      "properties": {
        "url": {
          "type": "object",
          "properties": {
            "host": {
              "type": "string"
            }
          }
        },
        "clusterName": {
          "type": "string"
        },
        "recommendationsPath": {
          "type": "string"
        },
        "requestTimeout": {
          "type": "string"
        }
      }
    },
    "kubexCredentials": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string"
        },
        "epassword": {
          "type": "string"
        },
        "userSecretName": {
          "type": "string"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "fsGroup": {
          "type": "integer"
        },
        "runAsGroup": {
          "type": "integer"
        },
        "runAsUser": {
          "type": "integer"
        },
        "runAsNonRoot": {
          "type": "boolean"
        },
        "seccompProfile": {
          "type": "object"
        }
      }
    },
    "securityContext": {
      "type": "object"
    },
    "resources": {
      "$ref": "#/definitions/resources"
    },
    "gateway": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object"
        },
        "configSecretName": {
          "type": "string"
        },
        "securityContext": {
          "type": "object"
        },
        "resources": {
          "$ref": "#/definitions/resources"
        }
      }
    },
    "cleanup": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object"
        },
        "podSecurityContext": {
          "type": "object"
        },
        "securityContext": {
          "type": "object"
        }
      }
    },
    "openshift": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "fsGroup": {
          "type": [
            "integer",
            "null"
          ]
        },
        "fsGroupChangePolicy": {
          "type": "string"
        },
        "supplementalGroups": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "controllerManager": {
      "type": "object",
      "properties": {
        "leaderElection": {
          "type": "object"
        },
        "healthProbeBindAddress": {
          "type": "string"
        },
        "metricsBindAddress": {
          "type": "string"
        },
        "extraArgs": {
          "type": "array"
        },
        "globalConfigReconcileInterval": {
          "type": "string"
        },
        "extraEnv": {
          "type": "array"
        }
      }
    },
    "globalConfiguration": {
      "type": "object",
      "properties": {
        "webhookHealth": {
          "type": "object",
          "properties": {
            "failureThreshold": {
              "type": "integer"
            },
            "successThreshold": {
              "type": "integer"
            },
            "transitionCheckInterval": {
              "type": "string"
            }
          }
        },
        "webhookProbe": {
          "type": "object",
          "properties": {
            "image": {
              "type": "string"
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "resources": {
              "$ref": "#/definitions/resources"
            },
            "podSecurityContext": {
              "type": "object"
            },
            "securityContext": {
              "type": "object"
            }
          }
        }
      }
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "policy": {
            "type": "string"
          },
          "weight": {
            "type": "integer"
          },
          "namespaces": {
            "type": "object",
            "properties": {
              "operator": {
                "type": "string"
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "podLabels": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "$ref": "#/definitions/resourceList"
        },
        "requests": {
          "$ref": "#/definitions/resourceList"
        }
      }
    },
    "resourceList": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "createSecrets": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "kubex",
          "kubexCredentials"
        ],
        "properties": {
          "kubex": {
            "required": [
              "url"
            ],
            "properties": {
              "url": {
                "required": [
                  "host"
                ],
                "properties": {
                  "host": {
                    "minLength": 1
                  }
                }
              }
            }
          },
          "kubexCredentials": {
            "required": [
              "username",
              "epassword"
            ],
            "properties": {
              "username": {
                "minLength": 1
              },
              "epassword": {
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
